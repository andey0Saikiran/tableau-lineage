{
  "name": "tableau-lineage-mcp",
  "version": "0.1.0",
  "description": "MCP server that lets AI assistants read the lineage inside Tableau workbooks (.twbx/.twb): calculated-field dependencies, formulas, parameters. Runs 100% locally — the workbook never leaves your machine.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://tableau-lineage.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andey0Saikiran/tableau-lineage.git",
    "directory": "mcp"
  },
  "author": "Sai Kiran Andey (https://www.linkedin.com/in/andeysaikiran/)",
  "bin": {
    "tableau-lineage-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "tableau",
    "twbx",
    "data-lineage",
    "calculated-fields",
    "business-intelligence",
    "claude",
    "ai"
  ],
  "scripts": {
    "build": "tsc --noEmit && esbuild src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=dist/index.js",
    "test": "npm run build && node test/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xmldom/xmldom": "^0.9.6",
    "fflate": "^0.8.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2"
  }
}
